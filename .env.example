# =============================================================================
# Neon CRM API credentials.
# Copy this file to `.env` and fill in the real values. `.env` is gitignored and
# NEVER committed. Full step-by-step: docs/getting-a-neon-api-key.md
# =============================================================================

# --- Step 1: Org ID ---------------------------------------------------------
# Neon CRM -> Settings cog -> Organization Profile -> Account Information -> Organization ID
NEON_ORG_ID=

# --- Step 2: API key --------------------------------------------------------
# Neon CRM -> Settings cog -> User Management -> (dedicated integration user) ->
# enable "API Access" -> copy the key.
# Recommendation: use a dedicated, read-only user. The key inherits that user's
# permissions, so avoid tying it to an admin account.
NEON_API_KEY=
